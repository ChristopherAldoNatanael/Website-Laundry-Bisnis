# Environment Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ==========================================
# SECURITY SETTINGS
# ==========================================

# Node Environment (development, production, test)
NODE_ENV=production

# Application URL
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ==========================================
# AUTHENTICATION & SESSION
# ==========================================

# JWT Secret (generate a strong random string: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret (generate a strong random string)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# CSRF Token Secret
CSRF_SECRET=your-csrf-secret-key-change-this-in-production

# ==========================================
# API SECURITY
# ==========================================

# API Rate Limit (requests per minute)
API_RATE_LIMIT=100

# API Key for external services (if needed)
API_KEY=your-api-key-here

# ==========================================
# DATABASE (if using database)
# ==========================================

# Database URL (use connection string with SSL in production)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Database connection pool size
# DB_POOL_SIZE=10

# ==========================================
# REDIS (for rate limiting & caching)
# ==========================================

# Redis URL (use SSL in production)
# REDIS_URL=rediss://:password@host:port

# ==========================================
# THIRD-PARTY SERVICES
# ==========================================

# Google Analytics (only use in production)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager
# GTM_ID=GTM-XXXXXX

# Facebook Pixel (if needed)
# FB_PIXEL_ID=XXXXXXXXXX

# WhatsApp Business API (if using)
# WHATSAPP_API_KEY=your-whatsapp-api-key
# WHATSAPP_PHONE_NUMBER=6281234567890

# ==========================================
# SECURITY HEADERS & CSP
# ==========================================

# Content Security Policy Nonce (generate dynamically in middleware)
# CSP_NONCE=

# Report URI for CSP violations
# CSP_REPORT_URI=https://yourdomain.com/api/csp-report

# ==========================================
# ENCRYPTION
# ==========================================

# Encryption Key for sensitive data (32 bytes for AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ==========================================
# MONITORING & LOGGING
# ==========================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Log level (error, warn, info, debug)
LOG_LEVEL=warn

# ==========================================
# FEATURE FLAGS
# ==========================================

# Enable/disable features
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_DEBUG_MODE=false

# ==========================================
# SECURITY WARNINGS
# ==========================================

# IMPORTANT SECURITY CHECKLIST:
# 1. Change ALL default secrets above
# 2. Use strong, unique passwords (min 32 characters)
# 3. Enable HTTPS only in production
# 4. Set up proper CORS origins
# 5. Configure rate limiting
# 6. Enable 2FA for admin accounts
# 7. Regular security audits
# 8. Keep dependencies updated
# 9. Use Web Application Firewall (WAF)
# 10. Monitor for suspicious activity

# NEVER SHARE THESE KEYS!
# NEVER COMMIT .env.local TO GIT!
